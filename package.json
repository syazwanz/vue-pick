{
  "name": "vue-pick",
  "version": "0.2.1",
  "description": "Accessible select components for Vue 2.7 and Vue 3",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./vue2": {
      "types": "./dist/vue2.d.ts",
      "import": "./dist/vue2.mjs",
      "require": "./dist/vue2.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syazwanz/vue-pick.git"
  },
  "homepage": "https://vue-pick.js.org",
  "bugs": {
    "url": "https://github.com/syazwanz/vue-pick/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue2",
    "select",
    "combobox",
    "dropdown",
    "accessible",
    "a11y",
    "aria"
  ],
  "scripts": {
    "dev": "vite --config sandbox/vue3/vite.config.ts",
    "dev:vue2": "vite --config sandbox/vue2/vite.config.ts",
    "build": "vite build && vite build --config vite.config.vue2.ts",
    "test": "vitest --config vitest.config.ts --run && vitest --config vitest.config.vue2.ts --run",
    "test:vue3": "vitest --config vitest.config.ts",
    "test:vue2": "vitest --config vitest.config.vue2.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": "^2.7.0 || ^3.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "shiki": "^4.0.2",
    "test-utils-vue2": "npm:@vue/test-utils@^1.3.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^1.6.0",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0",
    "vue2": "npm:vue@^2.7.16"
  },
  "pnpm": {
    "packageExtensions": {
      "vue-template-compiler@*": {
        "dependencies": {
          "vue": "*"
        }
      }
    },
    "overrides": {
      "@vitejs/plugin-vue2>vue": "npm:vue@^2.7.16",
      "vue-template-compiler>vue": "npm:vue@^2.7.16"
    }
  }
}
